{
  "name": "@folio/platform-minimal",
  "version": "0.1.0-SNAPSHOT",
  "license": "Apache-2.0",
  "scripts": {
    "build": "export NODE_OPTIONS=\"--max-old-space-size=4096 $NODE_OPTIONS\"; stripes build stripes.config.js",
    "stripes": "stripes",
    "start": "stripes serve stripes.config.js",
    "build-module-descriptors": "stripes mod descriptor stripes.config.js --output ./ModuleDescriptors",
    "local": "f=stripes.config.js; test -f $f.local && f=$f.local; echo Using config $f; stripes serve $f",
    "test": "echo 'No unit tests implemented'"
  },
  "dependencies": {
    "@folio/stripes": "^9.0.0",
    "@folio/users": ">=2.17.0",
    "@folio/workflow": "https://github.com/folio-org/ui-workflow.git#platform-complete-aggies",
    "moment": "~2.29.0",
    "react": "^18.2.0",
    "react-dom": "~18.2.0",
    "react-intl": "^6.4.4",
    "react-query": "^3.13.0",
    "react-redux": "^8.0.5",
    "react-router": "^5.2.0",
    "react-router-dom": "^5.2.0",
    "react-titled": "^2.0.0",
    "redux": "^4.2.1",
    "rxjs": "^6.6.7"
  },
  "devDependencies": {
    "@folio/stripes-cli": "^3.0.0",
    "@types/lodash": "^4.14.197",
    "eslint": "^6.2.1",
    "lodash": "^4.17.5"
  },
  "resolutions": {
    "colors": "1.4.0",
    "final-form": "^4.20.4",
    "minimist": "^1.2.3",
    "moment": "~2.29.0",
    "redux-form": "^8.0.0"
  }
}
