    "final-form": "^4.20.7",
    "final-form-arrays": "^3.0.2",
    "moment": "~2.29.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-final-form": "^6.5.9",
    "react-final-form-arrays": "^3.1.3",
    "react-intl": "^6.4.4",
    "react-query": "^3.13.0",
    "react-redux": "^8.0.5",
    "react-router": "^5.2.0",
    "react-router-dom": "^5.2.0",
    "react-titled": "^2.0.0",
    "redux": "^4.2.1",
    "redux-observable": "^1.2.0",
    "rxjs": "^6.6.7",
    "zustand": "^4.1.1"
